# Copy to .env for local dev. NEVER commit a real .env or key. Production = Railway secrets.
# This subsystem holds NO gateway/Google/finance/production credentials — only the below.
ENG_SERVICE_TOKEN=
# Least-privilege GitHub App (Contents r/w, Pull requests write; opt-in repos).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
# Maintainer allowlist (who may trigger) + opt-in repos (comma-separated).
ENG_MAINTAINERS=
ENG_REPOS=scottylabs-labrador/example
# Sandbox + result reporting.
SANDBOX_TEMPLATE=dev
ENG_TIME_LIMIT_MIN=20
SLACK_WEBHOOK_URL=
PORT=8080
