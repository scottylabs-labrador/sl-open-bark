# Copy to .env for local dev. NEVER commit a real .env. Production = Railway secrets.
# Slack app credentials (Appendix E scopes: app_mentions:read, chat:write, im:history,
# assistant:write, commands). Empty SLACK_SIGNING_SECRET disables signature checks (DEV ONLY).
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
# The runtime service the gateway drives in the background.
RUNTIME_URL=http://runtime.railway.internal:8080
RUNTIME_SERVICE_TOKEN=
PORT=8080
