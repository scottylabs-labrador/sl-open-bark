# Copy to .env for local dev. NEVER commit a real .env. Production = Railway secrets.
DATABASE_URL=postgres://postgres@localhost:5432/scottylabs?sslmode=disable
# Maintainer access token (empty = OPEN dev mode, no auth). Set in production.
DASHBOARD_TOKEN=change-me
# The runtime service (enables the agent console). Empty = console disabled.
RUNTIME_URL=http://runtime.railway.internal:8080
RUNTIME_SERVICE_TOKEN=
PORT=8080
