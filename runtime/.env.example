# Copy to .env for local development. NEVER commit a real .env or key. In production these come from
# Railway secrets.

# Model access via OpenRouter (design 5.5). Switching GOOSE_MODEL changes the model with no code
# change. Option B (generic OpenAI-compatible) also works — see the design doc.
GOOSE_PROVIDER=openrouter
GOOSE_MODEL=anthropic/claude-sonnet-4.6
GOOSE_ESCALATION_MODEL=anthropic/claude-opus-4.8
OPENROUTER_API_KEY=sk-or-...

# The MCP gateway the runtime registers as a Goose extension (all tools go through it).
GATEWAY_MCP_URL=http://gateway.railway.internal:8080/mcp
GATEWAY_SERVICE_TOKEN=change-me

# Where recipes are loaded from.
RECIPES_DIR=recipes
