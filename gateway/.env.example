# Copy to .env for local development. NEVER commit a real .env. In production these come from
# Railway secrets.

# Postgres DSN for the registry, approvals, and audit log (WP-01).
DATABASE_URL=postgres://postgres@localhost:5432/scottylabs?sslmode=disable

# Bearer the deployed agent and the dashboard present to the gateway policy API. Human callers
# authenticate via ContextForge's OAuth 2.1/PKCE in front of this service.
GATEWAY_SERVICE_TOKEN=change-me

# Bearer presented to downstream MCP servers (their MCP_AUTH_TOKEN). Held by the gateway only.
MCP_DOWNSTREAM_TOKEN=change-me

# The adopted MCP gateway (ContextForge) this policy layer cooperates with.
CONTEXTFORGE_URL=http://contextforge.railway.internal:4444

# Repo root for `gateway sync` (registering manifests). Railway injects PORT.
REPO_ROOT=.
PORT=8080
