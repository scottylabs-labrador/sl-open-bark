# Copy to .env for local development. NEVER commit a real .env or service-account key. In production
# these come from Railway secrets.

# Logging: debug | info | warn | error
MCP_LOG_LEVEL=info

# Bearer token the gateway presents to call this server (optional locally).
MCP_AUTH_TOKEN=change-me

# Google service-account key (domain-wide delegation). Provide EITHER the raw JSON in GOOGLE_SA_JSON
# OR a path in GOOGLE_SA_JSON_FILE. The delegation is scoped (Workspace admin grants only the scopes
# in internal/clients/google.go: Sheets read, Calendar events, Gmail compose+send, Drive read).
GOOGLE_SA_JSON=
GOOGLE_SA_JSON_FILE=

# The Workspace user the service account impersonates (the agent's own identity).
GOOGLE_DELEGATED_SUBJECT=agent@scottylabs.org

# Railway injects PORT in production.
PORT=8080
