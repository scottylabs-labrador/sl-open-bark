# Copy to .env for local development. NEVER commit a real .env. In production these come from
# Railway secrets.

# Logging: debug | info | warn | error
MCP_LOG_LEVEL=info

# Bearer token the MCP gateway must present to call this server (optional locally).
MCP_AUTH_TOKEN=change-me

# Optional external audit endpoint. If unset, audit events go to stdout.
MCP_AUDIT_URL=

# Railway injects PORT automatically in production; set it locally if you want.
PORT=8080
