# Copy to .env for local development. NEVER commit a real .env. In production these come from
# Railway secrets.

# Logging: debug | info | warn | error
MCP_LOG_LEVEL=info

# Bearer token the gateway presents to call this server (optional locally).
MCP_AUTH_TOKEN=change-me

# Optional: override the embedded, reviewed standards with a file path. Defaults to the embedded
# internal/standards/reimbursement.json.
FINANCE_STANDARDS_FILE=

# Railway injects PORT in production.
PORT=8080
